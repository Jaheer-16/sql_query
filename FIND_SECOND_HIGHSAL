1-Find the second highest salary from the Employee table.

SELECT  MAX(SALARY) AS [SECOND HIGH SAL]
FROM Employee
WHERE SALARY < (SELECT MAX(SALARY) FROM Employee);

------------------------------------------------------------------------------------------------------
SELECT * FROM
(
SELECT NAME,SALARY,
     ROW_NUMBER() OVER(ORDER BY CASE WHEN SALARY IS NULL THEN 0 ELSE SALARY END DESC) AS RANKING
	 FROM Employee
	 )t 
	 WHERE RANKING  = 2;
	 
-----------------------------------------------------------------------------------------------------
SELECT * FROM
(
SELECT NAME,SALARY,
     DENSE_RANK() OVER(ORDER BY CASE WHEN SALARY IS NULL THEN 0 ELSE SALARY END DESC) AS RANKING
	 FROM Employee
	 )t 
	 WHERE RANKING  = 2;
	 
